---
import Base from '../../layouts/Base.astro';
---

<Base title="Tải lên hóa đơn | AIEmployee.vn" description="Upload hóa đơn để trích xuất thông tin tự động bằng OCR" canonical="https://aiemployee.vn/tools/invoice-upload">

  <div class="container" style="padding-top: 120px; padding-bottom: 60px; max-width: 1000px;">
    <div class="page-header">
      <h1>Tải lên hóa đơn</h1>
      <p>OCR tự động trích xuất thông tin từ hóa đơn VAT Việt Nam</p>
    </div>

    <div class="upload-card">
      <div class="dropzone" id="dropzone">
        <input type="file" id="fileInput" accept="image/*,.pdf" style="display: none;">
        <div class="dropzone-icon">📄</div>
        <h3>Kéo thả file vào đây</h3>
        <p>hoặc click để chọn file</p>
        <p class="file-types">Hỗ trợ: JPEG, PNG, PDF</p>
      </div>

      <div class="upload-progress" id="uploadProgress" style="display: none;">
        <div class="progress-bar">
          <div class="progress-fill" id="progressFill"></div>
        </div>
        <p class="progress-text" id="progressText">Đang xử lý...</p>
      </div>
    </div>

    <div class="results-card" id="resultsCard" style="display: none;">
      <h2>Kết quả OCR</h2>
      <div class="result-fields" id="resultFields"></div>
      <div class="result-actions">
        <button class="btn btn-primary" id="copyResultBtn">
          <span>📋</span> Sao chép kết quả
        </button>
        <button class="btn btn-secondary" id="newUploadBtn">
          <span>↺</span> Upload mới
        </button>
      </div>
    </div>

    <div class="info-card">
      <h3>📋 Hướng dẫn</h3>
      <ul>
        <li>Upload hình ảnh hóa đơn VAT rõ ràng, có đủ thông tin</li>
        <li>Đảm bảo ánh sáng tốt, không bị mờ hoặc che khuất</li>
        <li>Hệ thống sẽ trích xuất: Tên công ty, MST, địa chỉ, các mặt hàng</li>
        <li>Kiểm tra lại thông tin trước khi sử dụng</li>
      </ul>
    </div>
  </div>

</Base>

<style>
  .container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 24px;
  }

  .page-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .page-header h1 {
    font-size: 32px;
    font-weight: 700;
    margin-bottom: 8px;
  }

  .page-header p {
    color: var(--gray);
    font-size: 16px;
  }

  .upload-card {
    background: var(--white);
    border-radius: 16px;
    padding: 40px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
    margin-bottom: 24px;
  }

  .dropzone {
    border: 2px dashed var(--border);
    border-radius: 12px;
    padding: 60px 40px;
    text-align: center;
    cursor: pointer;
    transition: all 0.3s;
    background: var(--light);
  }

  .dropzone:hover,
  .dropzone.dragover {
    border-color: var(--primary);
    background: #eff6ff;
  }

  .dropzone.uploading {
    pointer-events: none;
    opacity: 0.7;
  }

  .dropzone-icon {
    width: 64px;
    height: 64px;
    margin: 0 auto 16px;
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 28px;
  }

  .dropzone h3 {
    font-size: 20px;
    margin-bottom: 8px;
  }

  .dropzone p {
    color: var(--gray);
    margin-bottom: 8px;
  }

  .file-types {
    font-size: 13px;
    color: var(--gray);
  }

  .upload-progress {
    padding: 40px;
    text-align: center;
  }

  .progress-bar {
    height: 8px;
    background: var(--light);
    border-radius: 4px;
    overflow: hidden;
    margin-bottom: 16px;
  }

  .progress-fill {
    height: 100%;
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    border-radius: 4px;
    transition: width 0.3s ease;
    width: 0%;
  }

  .progress-text {
    color: var(--gray);
    font-size: 14px;
  }

  .results-card {
    background: var(--white);
    border-radius: 16px;
    padding: 40px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
    margin-bottom: 24px;
  }

  .results-card h2 {
    font-size: 24px;
    margin-bottom: 24px;
  }

  .result-fields {
    display: grid;
    gap: 16px;
    margin-bottom: 24px;
  }

  .result-field {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .result-field label {
    font-size: 12px;
    font-weight: 600;
    color: var(--gray);
    text-transform: uppercase;
  }

  .result-field span {
    font-size: 16px;
    padding: 12px;
    background: var(--light);
    border-radius: 8px;
  }

  .result-actions {
    display: flex;
    gap: 12px;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 12px 24px;
    border-radius: 8px;
    font-weight: 600;
    font-size: 14px;
    cursor: pointer;
    border: none;
    transition: all 0.2s;
  }

  .btn-primary {
    background: var(--primary);
    color: var(--white);
    flex: 1;
  }

  .btn-primary:hover {
    background: var(--primary-dark);
  }

  .btn-secondary {
    background: var(--white);
    color: var(--gray);
    border: 1px solid var(--border);
  }

  .btn-secondary:hover {
    background: var(--light);
  }

  .info-card {
    background: #fffbeb;
    border: 1px solid #fef3c7;
    border-radius: 12px;
    padding: 24px;
  }

  .info-card h3 {
    font-size: 16px;
    margin-bottom: 16px;
    color: #92400e;
  }

  .info-card ul {
    list-style: none;
    font-size: 14px;
    color: #a16207;
  }

  .info-card li {
    padding: 8px 0;
    padding-left: 24px;
    position: relative;
  }

  .info-card li::before {
    content: "•";
    position: absolute;
    left: 8px;
    color: #f59e0b;
  }
</style>

<script>
  import Tesseract from 'tesseract.js';

  const dropzone = document.getElementById('dropzone');
  const fileInput = document.getElementById('fileInput') as HTMLInputElement;
  const uploadProgress = document.getElementById('uploadProgress');
  const progressFill = document.getElementById('progressFill');
  const progressText = document.getElementById('progressText');
  const resultsCard = document.getElementById('resultsCard');
  const resultFields = document.getElementById('resultFields');
  const copyResultBtn = document.getElementById('copyResultBtn');
  const newUploadBtn = document.getElementById('newUploadBtn');

  let extractedData: any = null;

  // Click to upload
  dropzone.addEventListener('click', () => {
    fileInput.click();
  });

  // File selected
  fileInput.addEventListener('change', (e) => {
    const file = (e.target as HTMLInputElement).files?.[0];
    if (file) {
      processFile(file);
    }
  });

  // Drag and drop
  dropzone.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropzone.classList.add('dragover');
  });

  dropzone.addEventListener('dragleave', () => {
    dropzone.classList.remove('dragover');
  });

  dropzone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropzone.classList.remove('dragover');
    const file = e.dataTransfer.files?.[0];
    if (file) {
      processFile(file);
    }
  });

  async function processFile(file: File) {
    dropzone.classList.add('uploading');
    dropzone.style.display = 'none';
    uploadProgress.style.display = 'block';
    resultsCard.style.display = 'none';

    try {
      const result = await Tesseract.recognize(file, 'vie', {
        logger: (m) => {
          if (m.status === 'recognizing text') {
            const progress = Math.round(m.progress * 100);
            progressFill.style.width = `${progress}%`;
            progressText.textContent = `Đang nhận diện... ${progress}%`;
          }
        }
      });

      progressText.textContent = 'Đang trích xuất thông tin...';
      progressFill.style.width = '100%';

      extractedData = parseOCRResult(result.data.text);
      displayResults(extractedData);

      uploadProgress.style.display = 'none';
      resultsCard.style.display = 'block';
    } catch (error) {
      console.error('OCR Error:', error);
      progressText.textContent = 'Lỗi xử lý. Vui lòng thử lại.';
    }
  }

  function parseOCRResult(text: string) {
    const lines = text.split('\n').map(l => l.trim()).filter(l => l);

    // Extract tax code (MST format: XXXXXXXXXXXXX)
    const taxCodeMatch = text.match(/\b(\d{10,13})\b/);
    const taxCode = taxCodeMatch ? taxCodeMatch[1] : '';

    // Extract company name (usually first non-empty lines)
    let companyName = '';
    for (const line of lines.slice(0, 5)) {
      if (line.length > 5 && !line.match(/^\d/) && !line.match(/^MST/i)) {
        companyName = line;
        break;
      }
    }

    // Extract date
    const dateMatch = text.match(/(\d{1,2})[\/\-](\d{1,2})[\/\-](\d{2,4})/);
    const date = dateMatch ? `${dateMatch[1]}/${dateMatch[2]}/${dateMatch[3]}` : '';

    // Extract total amount
    const amountMatch = text.match(/(?:Tổng cộng|Total)[:\s]*(\d[\d.,]*)/i);
    const totalAmount = amountMatch ? amountMatch[1].replace(/[.,]/g, '') : '';

    return {
      companyName,
      taxCode,
      date,
      totalAmount,
      rawText: text
    };
  }

  function displayResults(data: any) {
    resultFields.innerHTML = `
      <div class="result-field">
        <label>Tên công ty</label>
        <span>${data.companyName || 'Không tìm thấy'}</span>
      </div>
      <div class="result-field">
        <label>Mã số thuế</label>
        <span>${data.taxCode || 'Không tìm thấy'}</span>
      </div>
      <div class="result-field">
        <label>Ngày</label>
        <span>${data.date || 'Không tìm thấy'}</span>
      </div>
      <div class="result-field">
        <label>Tổng tiền</label>
        <span>${data.totalAmount ? new Intl.NumberFormat('vi-VN').format(parseInt(data.totalAmount)) + ' VND' : 'Không tìm thấy'}</span>
      </div>
    `;
  }

  copyResultBtn.addEventListener('click', async () => {
    if (!extractedData) return;

    const text = `Hóa đơn - AIEmployee.vn
═══════════════════════════════
Tên công ty: ${extractedData.companyName || 'N/A'}
Mã số thuế: ${extractedData.taxCode || 'N/A'}
Ngày: ${extractedData.date || 'N/A'}
Tổng tiền: ${extractedData.totalAmount ? new Intl.NumberFormat('vi-VN').format(parseInt(extractedData.totalAmount)) + ' VND' : 'N/A'}`;

    try {
      await navigator.clipboard.writeText(text);
      const originalText = copyResultBtn.innerHTML;
      copyResultBtn.innerHTML = '<span>✓</span> Đã sao chép!';
      setTimeout(() => {
        copyResultBtn.innerHTML = originalText;
      }, 2000);
    } catch (err) {
      console.error('Failed to copy:', err);
    }
  });

  newUploadBtn.addEventListener('click', () => {
    dropzone.style.display = 'block';
    dropzone.classList.remove('uploading');
    resultsCard.style.display = 'none';
    fileInput.value = '';
    extractedData = null;
  });
</script>
